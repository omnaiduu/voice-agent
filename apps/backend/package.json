{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.95.0",
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0"
  },
  "scripts": {
    "dev": "bun --watch index.ts",
    "generate:sfu": "bunx openapi-typescript https://developers.cloudflare.com/realtime/static/calls-api-2024-05-21.yaml --output apps/backend/cloudflare-sfu/types.ts",
    "start:redis": "docker run -d --name redis-dev -p 6379:6379 -v redis-data:/data redis:7-alpine redis-server --appendonly yes"
  },
  "exports": {
    ".": "./index.ts",
    "./trpc": "./trpc.ts"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@trpc/server": "^11.16.0",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  }
}
