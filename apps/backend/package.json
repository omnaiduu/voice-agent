{
	"name": "backend",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"devDependencies": {
		"@hey-api/openapi-ts": "^0.95.0",
		"@types/node": "^25.5.2",
		"openapi-fetch": "^0.17.0",
		"openapi-typescript": "^7.13.0",
		"tsx": "^4.19.2"
	},
	"scripts": {
		"dev": "tsx watch index.ts",
		"generate:sfu": "pnpx openapi-typescript https://developers.cloudflare.com/realtime/static/calls-api-2024-05-21.yaml --output apps/backend/cloudflare-sfu/types.ts",
		"start:redis": "sudo service redis-server start",
		"stop:redis": "sudo service redis-server stop",
		"start": "node dist/index.js"
	},
	"exports": {
		".": "./index.ts",
		"./trpc": "./trpc.ts",
		"./roomTypes": "./types.ts"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@trpc/server": "^11.16.0",
		"dotenv": "^17.4.2",
		"ioredis": "^5.10.1",
		"zod": "^4.3.6"
	}
}
